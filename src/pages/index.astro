---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Image } from 'astro:assets';
import coachPhoto from '../assets/coach-photo.png';
import sessionPhoto from '../assets/session.jpg';
import logoImg from '../assets/logo.png';
import jeffPhoto from '../assets/jeff-photo.png';

const WA_HREF =
  'https://wa.me/6590696395?text=Hi%20Sheryl%2C%20I%20want%20to%20know%20more%20about%20the%20Freemind%20Body%20Inner%20Flow%20Activation%20workshop.';
const IG_HREF = 'https://www.instagram.com/freemindembodiedactivation/';
---

<Layout
  title="Freemind Embodied Flow Activation | Sheryl Chia"
  description="An embodied movement and nervous system awareness experience for emotional clarity, self-connection, and inner balance. With Sheryl Chia in Singapore."
>
  <!-- ── Nav ── -->
  <nav class="nav">
    <a href="/" class="nav-brand">
      <div class="nav-logo-wrap">
        <Image src={logoImg} alt="" width={180} height={180} loading="eager" class="nav-logo" />
      </div>
      <span class="nav-brand-text">Freemind Embodied Flow Activation</span>
    </a>
    <a href={IG_HREF} target="_blank" rel="noopener noreferrer" class="nav-ig" aria-label="Follow on Instagram">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
    </a>
  </nav>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-eyebrow">Embodied Movement · Singapore</span>
      <h1 class="hero-heading">
        Reconnect with<br>
        the <em>Intelligence</em><br>
        of Your Body
      </h1>
      <p class="hero-sub">
        An embodied movement and nervous system awareness experience
        that supports emotional clarity, self-connection, and inner balance.
      </p>
      <div class="hero-actions">
        <WhatsAppButton label="Book a trial session" size="large" />
      </div>
    </div>
    <div class="hero-img-wrap">
      <Image
        src={coachPhoto}
        alt="Sheryl Chia — Founder of Freemind Embodied Flow Activation"
        width={620}
        height={620}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- ── The Experience ── -->
  <section class="section experience">
    <div class="section-inner">
      <div class="exp-img-wrap">
        <Image
          src={sessionPhoto}
          alt="Freemind Body Inner Flow Activation — group session"
          width={1200}
          height={525}
          loading="lazy"
        />
      </div>
      <div class="exp-text">
        <div class="exp-heading-wrap">
          <span class="section-label">The Experience</span>
          <h2 class="exp-heading">
            An Invitation to<br>Slow Down &amp;<br>Return Inward
          </h2>
        </div>
        <div class="exp-right">
          <div class="exp-body">
            <p>
              Many of us spend our lives living mostly from the mind —
              thinking, analysing, controlling, pushing forward — while becoming
              slowly disconnected from our body's natural rhythm.
            </p>
            <p>
              Freemind Body Inner Flow Activation gently invites you back to yourself.
              Through movement, breath, sensory awareness, and stillness, you begin
              reconnecting with your body, emotions, intuition, and authentic expression.
            </p>
            <p>
              This is not about fixing yourself.<br>
              It is about remembering how to feel.
            </p>
          </div>
          <div class="exp-tags">
            <span class="tag">Gentle Movement</span>
            <span class="tag">Breathwork</span>
            <span class="tag">Sensory Awareness</span>
            <span class="tag">Nervous System</span>
            <span class="tag">Inner Flow</span>
            <span class="tag">Stillness</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Quote Strip ── -->
  <section class="quote-strip">
    <div class="section-inner">
      <span class="quote-mark" aria-hidden="true">"</span>
      <p class="quote-text">
        Healing does not always begin with more thinking.<br>
        Sometimes, it begins by learning how to feel again.
      </p>
      <span class="quote-source">Freemind Embodied Flow Activation</span>
    </div>
  </section>

  <!-- ── Meet Your Coaches ── -->
  <section class="section coaches">
    <div class="section-inner">

      <div class="coaches-head">
        <span class="section-label" style="justify-content:center">Meet Your Coaches</span>
        <h2 class="coaches-heading">Guided by Masters of Mind, Body &amp; Energy</h2>
      </div>

      <!-- Jeff — Master Coach -->
      <div class="coach">
        <div class="coach-photo-wrap">
          <Image
            src={jeffPhoto}
            alt="Master Jeff — Founder of Freemind"
            width={560}
            height={560}
            loading="lazy"
          />
        </div>
        <div class="coach-content">
          <span class="coach-role">Master Coach · Founder of Freemind</span>
          <h2 class="coach-name">Master Jeff</h2>
          <p class="coach-bio">
            Jeff is the <span class="key-source">connector to the Source</span> — awakening the creator within each person
            through art, energy, and mastery coaching. An artist and architect by training,
            he has spent over 20 years pioneering the intersection of mindfulness and creative
            expression, guiding students and professionals toward self-realisation and authentic purpose.
          </p>
          <ul class="creds">
            <li>Founder of Freemind Creative Energy</li>
            <li>Artist, architect by training &amp; former director of a design school</li>
            <li>20+ years in art, design &amp; mindfulness practice</li>
            <li>B.Arch, National University of Singapore</li>
            <li>M.Arch (History &amp; Theory), McGill University, Canada</li>
            <li>Creative Energy Art exhibited &amp; collected in Singapore, Hong Kong, Paris &amp; Seoul</li>
            <li>Creator of the Freemind Art &amp; Drawing Energy (Huaqi) process</li>
          </ul>
        </div>
      </div>

      <!-- Sheryl — Facilitator -->
      <div class="coach coach--reverse">
        <div class="coach-photo-wrap">
          <Image
            src={coachPhoto}
            alt="Sheryl Chia — Facilitator of Freemind Embodied Flow Activation"
            width={560}
            height={560}
            loading="lazy"
          />
        </div>
        <div class="coach-content">
          <span class="coach-role">Facilitator · Founder of Embodied Flow Activation</span>
          <h2 class="coach-name">Sheryl Chia</h2>
          <p class="coach-bio">
            Sheryl guides participants into <span class="key-embodied">body-awareness and embodied presence</span> through
            movement, breathwork, and sensory awareness practices. Her work integrates years
            of dance training, holistic study, and nervous system grounding into deeply
            transformative experiences for everyday people.
          </p>
          <ul class="creds">
            <li>Founder of Freemind Embodied Flow Activation</li>
            <li>Royal Academy of Dance (RAD) Intermediate Certified</li>
            <li>Certified Aura-Soma Practitioner</li>
            <li>Background in dance, embodied movement &amp; holistic awareness</li>
            <li>Facilitator in body-awareness, emotional expression &amp; inner flow</li>
            <li>Integrates movement, breathwork &amp; nervous system grounding practices</li>
            <li>Experienced in guiding self-connection &amp; embodied awareness sessions</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Closing CTA ── -->
  <section class="section cta-section">
    <div class="section-inner">
      <span class="section-label cta-label">Begin Your Journey</span>
      <h2 class="cta-heading">Ready to Reconnect<br>with Yourself?</h2>
      <p class="cta-sub">
        Reach out directly and Sheryl will guide you to the right experience for you.
      </p>
      <div class="cta-actions">
        <WhatsAppButton label="Chat with us on WhatsApp" size="large" />
      </div>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">Freemind Embodied Flow Activation</span>
      <div class="footer-links">
        <a href={WA_HREF} target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href={IG_HREF} target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
      <span class="footer-copy">&copy; 2025 Freemind Embodied Flow Activation. All rights reserved.</span>
    </div>
  </footer>

  <!-- ── Floating WhatsApp ── -->
  <a
    href={WA_HREF}
    class="float-wa"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with Sheryl on WhatsApp"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
  </a>
</Layout>
